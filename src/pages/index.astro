---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Layout title="Spes's BLOG">
  <Sidebar slot="sidebar" />
  <h2 class="text-3xl font-bold mb-8">最新文章</h2>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {sortedPosts.map((post) => (
      <article class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-3xl p-7 shadow-sm hover:shadow-md transition-shadow">
        <a href={`/posts/${post.id}/`}>
          <h3 class="text-2xl font-semibold hover:text-blue-600">{post.data.title}</h3>
          <p class="text-sm text-zinc-500 mt-2">{post.data.pubDate.toLocaleDateString('zh-CN')}</p>
        </a>
      </article>
    ))}
  </div>
</Layout>
