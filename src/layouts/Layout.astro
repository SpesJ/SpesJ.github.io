---
import '../styles/global.css';
const { title = "Spes's BLOG" } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body class="bg-zinc-50 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 antialiased">
  <div class="flex items-start gap-12 px-10 py-12">
    <slot name="sidebar" />
    <main class="flex-1">
      <slot />
    </main>
  </div>
</body>
</html>
